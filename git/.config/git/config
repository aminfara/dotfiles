[init]
    defaultBranch = main

[user]
    email = ali.aminfar@gmail.com
    name = Ali 🚶

[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true       # use n/N to jump between hunks
    side-by-side = false   # optional: side-by-side diffs
    line-numbers = true

[pull]
    ff = only
    rebase = true

[merge]
    autoStash = true
    conflictStyle = zdiff3

[rebase]
    autoStash = true

[branch]
	sort = -committerdate    # Sort branches by most recent commit first
