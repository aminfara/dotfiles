{
  "mcpServers": {
    "tavily": {
      "type": "http",
      "url": "https://mcp.tavily.com/mcp/",
      "tools": ["*"]
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp/oauth",
      "tools": ["*"]
    },
    "gh-grep": {
      "type": "http",
      "url": "https://mcp.grep.app",
      "tools": ["*"]
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"],
      "tools": ["*"]
    },
    "ios-simulator": {
      "command": "npx",
      "args": ["-y", "ios-simulator-mcp"],
      "tools": ["*"]
    },
    "drawio": {
      "command": "npx",
      "args": ["-y", "@drawio/mcp"],
      "tools": ["*"]
    },
    "task-scheduler": {
      "command": "python3",
      "args": ["${userHome}/.config/copilot/mcp/task_scheduler_mcp.py"],
      "tools": ["*"]
    }
  }
}
